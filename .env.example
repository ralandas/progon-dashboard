# ─── Resend ────────────────────────────────────────────────
# Resend API key — same one used by the broadcast script.
# Get it from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# ─── Basic Auth (optional but recommended in prod) ─────────
# If both set, all routes require Basic auth.
# Leave empty for unauthenticated local dev.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ─── Replies storage path (optional) ───────────────────────
# Default: /tmp/replies.json on Vercel, ./data/replies.json locally.
# On Vercel /tmp is ephemeral per container — reset on cold start.
# For persistent storage swap to Vercel KV / Edge Config later.
REPLIES_FILE=
