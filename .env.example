# ─── Resend ────────────────────────────────────────────────
# Resend API key — same one used by the broadcast script.
# Get it from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# ─── Basic Auth (optional but recommended in prod) ─────────
# If both set, all routes require Basic auth.
# Leave empty for unauthenticated local dev.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ─── Replies storage path (optional) ───────────────────────
# Used only if Redis env vars are not set. Otherwise replies live in Redis.
REPLIES_FILE=

# ─── Upstash Redis ─────────────────────────────────────────
# Either set both (preferred): KV_REST_API_URL + KV_REST_API_TOKEN
# (Vercel auto-injects these when you connect an Upstash store via Storage tab.)
# OR set UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN with the same values.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── IMAP (auto-replied) ───────────────────────────────────
# Polls progon.pro@mail.ru inbox every 10 min via Vercel Cron,
# marks any reply from a known recipient as "replied" automatically.
#
# For mail.ru you need an APP PASSWORD (not the account password):
# https://account.mail.ru/user/2-step-auth/passwords
# Enable 2FA first, then create an external-app password.
IMAP_HOST=imap.mail.ru
IMAP_PORT=993
IMAP_USER=progon.pro@mail.ru
IMAP_PASSWORD=

# ─── Cron auth (optional) ──────────────────────────────────
# If set, /api/imap-sync requires Bearer <CRON_SECRET> for GET requests.
# Vercel Cron automatically sends this header. Manual POST from UI bypasses it.
CRON_SECRET=
